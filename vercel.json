{
  "functions": {
    "api/refresh.js": {
      "maxDuration": 10
    },
    "api/refresh-status.js": {
      "maxDuration": 10
    },
    "api/login.js": {
      "maxDuration": 10
    },
    "api/me.js": {
      "maxDuration": 10
    },
    "api/board.js": {
      "maxDuration": 10
    },
    "api/team-user.js": {
      "maxDuration": 10
    },
    "api/logout.js": {
      "maxDuration": 10
    },
    "api/static.js": {
      "maxDuration": 10,
      "includeFiles": "assets/**"
    }
  },
  "routes": [
    { "src": "/api/login", "dest": "/api/login.js" },
    { "src": "/api/logout", "dest": "/api/logout.js" },
    { "src": "/api/me", "dest": "/api/me.js" },
    { "src": "/api/board", "dest": "/api/board.js" },
    { "src": "/api/team-user", "dest": "/api/team-user.js" },
    { "src": "/api/refresh", "dest": "/api/refresh.js" },
    { "src": "/api/refresh-status", "dest": "/api/refresh-status.js" },
    { "src": "/(.*)", "dest": "/api/static.js" }
  ]
}
